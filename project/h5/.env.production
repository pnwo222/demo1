#生产环境配置

# 接口地址
VITE_API_BASE_URL=https://icard.nbecard.com

# 登录重定向地址
VITE_API_REDIRECT=https://icard.nbecard.com/fangyuan/auth/c/threeCenters/redirect

# 接口地址前缀
VITE_API_URL_PREFIX=/fangyuan

# 发布路径
VITE_PUBLIC_PATH=./

# 是否使用mock数据
VITE_USE_MOCK=false

# 是否打开vconsole
VITE_USE_VCONSOLE=false

# 是否生成依赖分析文件 根目录 stats.html
VITE_USE_REPORT=true