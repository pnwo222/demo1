{
  "name": "demo-h5",
  "version": "1.0.0",
  "description": "template for Vue3 vite h5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "http://gitlab.nbpitech.com/front/demo-h5"
  },
  "scripts": {
    "serve": "pnpm run dev",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:pro": "vite build",
    "build:test": "vite build --mode=test && deploy",
    "build:pre": "vite build --mode=pre",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "stylelint": "stylelint \"src/**/*.{css,less,vue}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,less,vue}\" --fix",
    "preview": "vite preview",
    "test": "vitest",
    "prepare": "npx husky install"
  },
  "dependencies": {
    "@vant/touch-emulator": "^1.4.0",
    "@vant/use": "^1.5.1",
    "@vueuse/core": "^10.1.2",
    "axios": "^1.4.0",
    "compressorjs": "^1.2.1",
    "crypto-js": "^4.1.1",
    "dayjs": "^1.11.9",
    "html2canvas": "^1.4.1",
    "icard-jssdk": "1.0.1-alpha.22",
    "lodash-es": "^4.17.21",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.0.35",
    "pinia-plugin-persistedstate": "^3.1.0",
    "postcss-px-to-viewport-8-plugin": "^1.2.2",
    "qrcode": "^1.5.4",
    "qs": "^6.11.2",
    "vant": "^4.9.21",
    "vconsole": "^3.15.0",
    "vue": "^3.3.4",
    "vue-i18n": "^9.2.2",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "5.1.0",
    "@babel/core": "^7.21.5",
    "@babel/preset-env": "^7.21.5",
    "@babel/preset-typescript": "^7.21.5",
    "@babel/register": "^7.21.0",
    "@types/lodash-es": "^4.17.7",
    "@types/node": "^18.16.3",
    "@types/nprogress": "^0.2.0",
    "@unocss/preset-attributify": "^0.54.1",
    "@unocss/preset-rem-to-px": "^0.54.1",
    "@unocss/preset-uno": "^0.54.1",
    "@unocss/transformer-directives": "^0.53.6",
    "@vitejs/plugin-legacy": "^3.0.2",
    "@vitejs/plugin-vue": "^4.2.1",
    "@vitejs/plugin-vue-jsx": "^3.0.1",
    "autoprefixer": "^10.4.14",
    "cross-env": "^7.0.3",
    "eslint": "^9.32.0",
    "husky": "^8.0.3",
    "less": "^4.1.3",
    "mockjs": "^1.1.0",
    "postcss-html": "^1.5.0",
    "postcss-less": "4.0.0",
    "rollup-plugin-visualizer": "^5.9.2",
    "stylelint": "^16.23.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.1.0",
    "stylelint-config-recommended": "^14.0.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-less": "^3.0.1",
    "stylelint-order": "^7.0.0",
    "terser": "5.4.0",
    "typescript": "^5.1.3",
    "unocss": "^0.54.1",
    "unplugin-auto-import": "^0.12.2",
    "unplugin-vue-components": "^0.22.12",
    "vite": "^4.4.8",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.0",
    "vite-plugin-mock": "^2.9.8",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vconsole": "^1.3.1",
    "vitest": "^0.25.8",
    "vue-tsc": "^1.6.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "postcss"
      ],
      "ignoreMissing": [
        "postcss"
      ]
    }
  }
}
