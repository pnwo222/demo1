# 预发环境配置

VITE_APP_CODE=zfit

# 接口地址
VITE_API_BASE_URL=https://icard-pre.nbecard.com:9443

# 登录重定向地址
VITE_API_REDIRECT=https://icard-pre.nbecard.com:9443/fangyuan/auth/c/threeCenters/redirect

# 接口地址前缀
VITE_API_URL_PREFIX=/fangyuan

# 发布路径
VITE_PUBLIC_PATH=./

# 是否使用mock数据
VITE_USE_MOCK=false

# 是否打开vconsole
VITE_USE_VCONSOLE=true

# 是否生成依赖分析文件 根目录 stats.html
VITE_USE_REPORT=true